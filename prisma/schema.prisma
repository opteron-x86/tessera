generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CardRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum MatchMode {
  PVE
  PVP
}

enum MatchPhase {
  LOBBY
  ACTIVE
  COMPLETE
  ABANDONED
}

enum LedgerReason {
  MATCH_REWARD
  BOOSTER_PURCHASE
  CARD_TRANSMUTE
  ADMIN_GRANT
}

enum EntitlementKind {
  DECK_SLOT
  CARD_SLEEVE
  CARD_BORDER
  ALT_ART
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  profile      PlayerProfile?
  cards        CardInstance[]
  decks        Deck[]
  ledgers      CurrencyLedger[]
  pveProgress  PveProgress[]
  matchesAsOne Match[]          @relation("MatchPlayerOne")
  matchesAsTwo Match[]          @relation("MatchPlayerTwo")
  entitlements Entitlement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PlayerProfile {
  userId    String   @id
  currency  Int      @default(500)
  deckSlots Int      @default(3)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CardTemplate {
  id              String         @id
  name            String
  series          String         @default("core")
  collectorNumber String?
  rarity          CardRarity
  tier            Int            @default(1)
  affinity        String?
  sides           Json
  lore            String         @db.Text
  artUrl          String?
  palette         Json?
  isStarter       Boolean        @default(false)
  isPublished     Boolean        @default(true)
  cards           CardInstance[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model CardInstance {
  id            String       @id @default(cuid())
  ownerId       String
  templateId    String
  upgradeLevel  Int          @default(0)
  sleeveId      String?
  borderId      String?
  altArtId      String?
  isLocked      Boolean      @default(false)
  owner         User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  template      CardTemplate @relation(fields: [templateId], references: [id])
  deckPositions DeckCard[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([ownerId])
  @@index([templateId])
}

model Deck {
  id        String     @id @default(cuid())
  ownerId   String
  name      String
  isActive  Boolean    @default(false)
  owner     User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  cards     DeckCard[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([ownerId])
}

model DeckCard {
  deckId     String
  cardId     String
  position   Int
  deck       Deck         @relation(fields: [deckId], references: [id], onDelete: Cascade)
  card       CardInstance @relation(fields: [cardId], references: [id], onDelete: Cascade)
  assignedAt DateTime     @default(now())

  @@id([deckId, position])
  @@unique([deckId, cardId])
}

model CurrencyLedger {
  id        String       @id @default(cuid())
  userId    String
  amount    Int
  reason    LedgerReason
  metadata  Json?
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@index([userId])
}

model BoosterPack {
  id          String   @id
  name        String
  price       Int
  slots       Json
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PveOpponent {
  id              String        @id
  name            String
  difficulty      Int
  deckTemplateIds Json
  ruleSet         Json
  rewardCurrency  Int
  tutorialCopy    String        @db.Text
  unlockAfterId   String?
  progress        PveProgress[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PveProgress {
  userId      String
  opponentId  String
  wins        Int         @default(0)
  bestScore   Int?
  completedAt DateTime?
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opponent    PveOpponent @relation(fields: [opponentId], references: [id])

  @@id([userId, opponentId])
}

model Match {
  id          String       @id @default(cuid())
  mode        MatchMode
  phase       MatchPhase   @default(LOBBY)
  playerOneId String
  playerTwoId String?
  playerOne   User         @relation("MatchPlayerOne", fields: [playerOneId], references: [id], onDelete: Cascade)
  playerTwo   User?        @relation("MatchPlayerTwo", fields: [playerTwoId], references: [id], onDelete: SetNull)
  opponentId  String?
  ruleSet     Json
  seed        String
  state       Json
  winnerId    String?
  events      MatchEvent[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  completedAt DateTime?

  @@index([playerOneId])
  @@index([playerTwoId])
}

model MatchEvent {
  id        String   @id @default(cuid())
  matchId   String
  sequence  Int
  actorId   String?
  eventType String
  payload   Json
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([matchId, sequence])
  @@index([matchId])
}

model Entitlement {
  id        String          @id @default(cuid())
  userId    String
  kind      EntitlementKind
  key       String
  source    String
  metadata  Json?
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())

  @@unique([userId, kind, key])
  @@index([userId])
}
